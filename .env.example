APP_NAME=IELTS Audio Assessment API
ENVIRONMENT=development

REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

WHISPERX_MODEL_NAME=large-v3
WHISPERX_COMPUTE_TYPE=float16
WHISPERX_BATCH_SIZE=8
WHISPERX_DEVICE=cuda
WHISPERX_LANGUAGE=
HF_AUTH_TOKEN=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

API_KEY=your-secret-api-key-here
CLOUDFLARE_TUNNEL_TOKEN=
PUBLIC_API_BASE_URL=
FRONTEND_API_BASE_URL=

PAUSE_THRESHOLD_SECONDS=0.40
LOW_CONFIDENCE_THRESHOLD=0.60
ENABLE_VAD_PAUSE_REFINEMENT=true
VAD_AGGRESSIVENESS=2
VAD_FRAME_MS=30
FILLER_CONTEXT_PAUSE_SECONDS=0.15

SCORING_CALIBRATION_SCALE=1.0
SCORING_CALIBRATION_BIAS=0.0

UPLOAD_DIR=uploads
REPORTS_DIR=reports
FFMPEG_PATH=ffmpeg
MAX_UPLOAD_SIZE_MB=25

# Retention: hours to keep audio after report is saved (0=immediate, -1=forever)
AUDIO_RETENTION_HOURS=24
